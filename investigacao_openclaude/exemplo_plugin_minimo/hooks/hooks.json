{
  "hooks": [
    {
      "matcher": "Bash",
      "if": "Bash(rm* -rf*)",
      "hooks": [
        {
          "type": "command",
          "command": "bash hooks/pre-tool-use-safety.sh",
          "shell": "bash",
          "description": "Bloqueia comandos shell perigosos antes da execução"
        }
      ]
    },
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "bash hooks/post-write-log.sh",
          "shell": "bash",
          "async": true,
          "description": "Registra arquivos modificados para auditoria"
        }
      ]
    },
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bash hooks/on-stop-summary.sh",
          "shell": "bash",
          "description": "Gera resumo da sessão ao finalizar"
        }
      ]
    }
  ]
}
