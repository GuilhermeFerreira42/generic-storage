{
  "mcpServers": {
    "greenforge-storage": {
      "command": "node",
      "args": ["${pluginRoot}/mcp-servers/storage/index.js"],
      "env": {
        "GREENFORGE_LOG_LEVEL": "info",
        "GREENFORGE_STORAGE_PATH": "~/.greenforge/state.db"
      },
      "description": "Servidor MCP para persistência de estado do GreenForge (SQLite)"
    },
    "greenforge-metrics": {
      "command": "python3",
      "args": ["${pluginRoot}/mcp-servers/metrics/server.py"],
      "env": {
        "GREENFORGE_METRICS_PORT": "3001",
        "GREENFORGE_ANALYTICS_ENABLED": "true"
      },
      "description": "Servidor MCP para coleta de métricas de sustentabilidade"
    }
  }
}
