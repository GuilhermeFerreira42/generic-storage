# GreenForge Server .gitignore

# Dependencies
node_modules/

# Build output
dist/

# Environment files (NEVER commit secrets)
.env
.env.local
.env.*.local

# Database
*.db
*.sqlite
*.sqlite3

# Keys and secrets
*.key
*.pem
*.cert
*.secret
id_rsa
id_ed25519

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Worker directories
.greenforge-workers/
