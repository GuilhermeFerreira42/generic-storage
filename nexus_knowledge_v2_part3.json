  "data_models": [
    {
      "nome": "ProjectContext",
      "descricao": "Contexto completo do projeto fornecido pelo usuário",
      "schema": {
        "type": "object",
        "required": ["project_description", "current_state"],
        "properties": {
          "project_description": {
            "type": "string",
            "minLength": 50,
            "description": "Descrição do projeto em linguagem natural (mínimo 50 palavras)"
          },
          "current_state": {
            "type": "object",
            "required": ["has_prior_prd", "implemented_phases"],
            "properties": {
              "has_prior_prd": {
                "type": "boolean",
                "description": "Se já existe PRD anterior"
              },
              "implemented_phases": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Fases já implementadas (lista ou 'nenhuma')"
              },
              "architectural_decisions": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Decisões arquiteturais já tomadas"
              },
              "constraints": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Restrições conhecidas (tecnologia, prazo, equipe)"
              }
            }
          },
          "target_audience": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Segmentos de público-alvo identificados"
          },
          "integrations": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Integrações externas necessárias"
          }
        }
      },
      "example": {
        "project_description": "Sistema de automação de documentação técnica que transforma descrições vagas de projetos em PRDs completos, arquitetura detalhada e planos de implementação seguindo padrões rigorosos de qualidade.",
        "current_state": {
          "has_prior_prd": false,
          "implemented_phases": [],
          "architectural_decisions": [],
          "constraints": ["Deve ser implementado em TypeScript", "Prazo de 4 semanas"]
        },
        "target_audience": ["Engenheiros de software", "Product Managers técnicos"],
        "integrations": ["API Anthropic Claude", "API OpenAI GPT"]
      }
    },
    {
      "nome": "AnalysisResult",
      "descricao": "Resultado da análise de contexto pelo ContextAnalyzer",
      "schema": {
        "type": "object",
        "required": ["status", "sections"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["complete", "incomplete", "blocked"]
          },
          "sections": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["ready", "missing_fields"],
              "properties": {
                "ready": {"type": "boolean"},
                "missing_fields": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "blocking_questions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["question", "field"],
                    "properties": {
                      "question": {"type": "string"},
                      "field": {"type": "string"}
                    }
                  }
                }
              }
            }
          },
          "inherited_decisions": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      },
      "example": {
        "status": "blocked",
        "sections": {
          "visao_produto": {
            "ready": true,
            "missing_fields": [],
            "blocking_questions": []
          },
          "decisoes_arquiteturais": {
            "ready": false,
            "missing_fields": ["prior_decisions"],
            "blocking_questions": [
              {
                "question": "Quais decisões arquiteturais já foram tomadas para este projeto?",
                "field": "prior_decisions"
              }
            ]
          }
        },
        "inherited_decisions": []
      }
    },
    {
      "nome": "ComponentBlueprint",
      "descricao": "Especificação completa de um componente arquitetural",
      "schema": {
        "type": "object",
        "required": ["id", "name", "responsibility", "interfaces"],
        "properties": {
          "id": {"type": "string", "pattern": "^COMP-\\d{3}$"},
          "name": {"type": "string"},
          "responsibility": {"type": "string"},
          "dependencies": {
            "type": "array",
            "items": {"type": "string"}
          },
          "public_interfaces": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "signature", "description"],
              "properties": {
                "name": {"type": "string"},
                "signature": {"type": "string"},
                "description": {"type": "string"}
              }
            }
          },
          "events_emits": {
            "type": "array",
            "items": {"type": "string"}
          },
          "events_listens": {
            "type": "array",
            "items": {"type": "string"}
          },
          "configurations": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["default", "type"],
              "properties": {
                "default": {},
                "type": {"type": "string", "enum": ["string", "number", "boolean", "object"]},
                "constraints": {"type": "object"},
                "description": {"type": "string"}
              }
            }
          }
        }
      },
      "example": {
        "id": "COMP-001",
        "name": "ContextAnalyzer",
        "responsibility": "Analisar contexto e identificar informações faltantes",
        "dependencies": ["ProjectSchema", "SectionValidator"],
        "public_interfaces": [
          {
            "name": "analyzeContext",
            "signature": "analyzeContext(rawContext: ProjectContext): AnalysisResult",
            "description": "Recebe contexto bruto e retorna resultado da análise"
          }
        ],
        "events_emits": ["context.analyzed", "section.blocked"],
        "events_listens": ["user.context_submitted"],
        "configurations": {
          "MIN_CONTEXT_WORDS": {
            "default": 50,
            "type": "number",
            "constraints": {"min": 10, "max": 500},
            "description": "Número mínimo de palavras na descrição"
          }
        }
      }
    },
    {
      "nome": "ADR",
      "descricao": "Architecture Decision Record - registro formal de decisão arquitetural",
      "schema": {
        "type": "object",
        "required": ["id", "status", "decision", "alternatives_rejected"],
        "properties": {
          "id": {"type": "string", "pattern": "^ADR-\\d{3}$"},
          "status": {"type": "string", "enum": ["Aceita", "Rejeitada", "Proposta"]},
          "date": {"type": "string", "format": "date"},
          "context": {"type": "string"},
          "decision": {"type": "string"},
          "alternatives_rejected": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["alternative", "reason"],
              "properties": {
                "alternative": {"type": "string"},
                "reason": {"type": "string"}
              }
            }
          },
          "positive_consequences": {
            "type": "array",
            "items": {"type": "string"}
          },
          "negative_consequences": {
            "type": "array",
            "items": {"type": "string"}
          },
          "mitigation": {"type": "string"},
          "impact": {"type": "string"},
          "related_requirements": {
            "type": "array",
            "items": {"type": "string", "pattern": "^(RF|RNF)-\\d{3}$"}
          }
        }
      },
      "example": {
        "id": "ADR-001",
        "status": "Aceita",
        "date": "2024-01-10",
        "context": "Precisávamos garantir integridade da documentação gerada",
        "decision": "Implementar regra de parada por informação faltante",
        "alternatives_rejected": [
          {
            "alternative": "Preencher com placeholders 'A DEFINIR'",
            "reason": "Viola princípio de determinismo e auditabilidade"
          }
        ],
        "positive_consequences": ["Garante 100% de integridade", "Força contexto completo"],
        "negative_consequences": ["Requer múltiplas interações"],
        "mitigation": "Sistema de checkpointing para retomada instantânea",
        "impact": "AFETA COMP-001, COMP-005",
        "related_requirements": ["RF-001", "RNF-002"]
      }
    },
    {
      "nome": "FlowDefinition",
      "descricao": "Definição estruturada de um fluxo principal do sistema",
      "schema": {
        "type": "object",
        "required": ["name", "actors", "steps"],
        "properties": {
          "name": {"type": "string"},
          "actors": {
            "type": "array",
            "items": {"type": "string"}
          },
          "preconditions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "steps": {
            "type": "array",
            "items": {"type": "string"}
          },
          "postconditions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "exceptions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["condition", "result"],
              "properties": {
                "condition": {"type": "string"},
                "result": {"type": "string"},
                "failure_counter": {"type": "string"}
              }
            }
          }
        }
      },
      "example": {
        "name": "Geração Completa de Documentação NEXUS",
        "actors": ["Usuário", "ContextAnalyzer", "ProductVisionGenerator", "ComponentArchitect"],
        "preconditions": ["Usuário tem descrição do projeto", "Sistema NEXUS está configurado"],
        "steps": [
          "1. Usuário submete contexto via formulário",
          "2. ContextAnalyzer valida completude",
          "3. ContextAnalyzer verifica readiness da seção Visão do Produto",
          "4. ProductVisionGenerator cria Parte 1"
        ],
        "postconditions": ["Documento NEXUS completo salvo", "JSON de conhecimento extraído"],
        "exceptions": [
          {
            "condition": "Contexto insuficiente para seção X",
            "result": "Sistema para e lista perguntas objetivas",
            "failure_counter": "N/A"
          }
        ]
      }
    },
    {
      "nome": "Requirement",
      "descricao": "Requisito funcional ou não-funcional com critério de aceite",
      "schema": {
        "type": "object",
        "required": ["id", "description", "acceptance_criteria", "priority"],
        "properties": {
          "id": {"type": "string", "pattern": "^(RF|RNF)-\\d{3}$"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "acceptance_criteria": {"type": "string"},
          "priority": {"type": "string", "enum": ["Must", "Should", "Could", "Wont"]},
          "category": {"type": "string"},
          "metric": {"type": "string"},
          "target": {"type": "string"},
          "responsible_component": {"type": "string", "pattern": "^COMP-\\d{3}$"},
          "tests": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "scenario", "criterion"],
              "properties": {
                "name": {"type": "string"},
                "scenario": {"type": "string"},
                "criterion": {"type": "string"}
              }
            }
